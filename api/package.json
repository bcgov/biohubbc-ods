{
  "name": "biohub-api",
  "version": "0.0.0",
  "description": "API for BioHub Web App",
  "license": "Apache-2.0",
  "main": "app",
  "repository": {
    "type": "git",
    "url": "https://github.com/bcgov/biohubbc-platform.git"
  },
  "scripts": {
    "start": "ts-node src/app",
    "clean": "gulp clean",
    "build": "gulp build",
    "start-reload": "./node_modules/.bin/nodemon src/app.ts --exec ts-node",
    "queue": "ts-node src/queue",
    "queue-reload": "./node_modules/.bin/nodemon src/queue.ts --exec ts-node",
    "test": "mocha",
    "test-watch": "mocha --watch",
    "coverage": "nyc mocha",
    "lint": "eslint . --ignore-pattern 'node_modules' --ext .ts",
    "lint-fix": "eslint . --fix --ignore-pattern 'node_modules' --ext .ts",
    "format": "prettier --check \"./src/**/*.{js,jsx,ts,tsx,css,scss}\"",
    "format-fix": "prettier --write \"./src/**/*.{js,jsx,ts,tsx,json,css,scss}\""
  },
  "engines": {
    "node": ">= 14.0.0",
    "npm": ">= 6.0.0"
  },
  "dependencies": {
    "@elastic/elasticsearch": "~8.1.0",
    "adm-zip": "^0.5.10",
    "ajv": "~8.6.3",
    "aws-sdk": "^2.1396.0",
    "axios": "~0.21.4",
    "clamdjs": "~1.0.2",
    "db-migrate": "^0.11.13",
    "db-migrate-pg": "^1.2.4",
    "express": "^4.17.3",
    "express-openapi": "^9.3.1",
    "fast-json-patch": "~3.1.1",
    "fast-xml-parser": "^4.1.4",
    "fastq": "^1.15.0",
    "jsonpath-plus": "~7.2.0",
    "jsonwebtoken": "~8.5.1",
    "jwks-rsa": "~2.0.5",
    "knex": "~2.4.2",
    "lodash": "~4.17.21",
    "mime": "~2.5.2",
    "moment": "^2.29.4",
    "multer": "~1.4.3",
    "object-inspect": "~1.12.3",
    "openapi-request-validator": "^11.0.1",
    "openapi-response-validator": "^11.0.1",
    "p-queue": "^7.3.3",
    "pg": "^8.7.3",
    "qs": "^6.10.4",
    "sql-template-strings": "~2.2.2",
    "swagger-ui-express": "~4.3.0",
    "typescript": "~4.2.4",
    "uuid": "~8.3.2",
    "winston": "^3.3.4",
    "xlsx": "^0.17.5",
    "zod": "^3.21.4"
  },
  "devDependencies": {
    "@istanbuljs/nyc-config-typescript": "^1.0.2",
    "@types/adm-zip": "~0.4.34",
    "@types/chai": "~4.2.22",
    "@types/express": "^4.17.17",
    "@types/geojson": "^7946.0.10",
    "@types/gulp": "^4.0.11",
    "@types/jsonwebtoken": "^8.5.9",
    "@types/lodash": "^4.14.195",
    "@types/mime": "~2.0.3",
    "@types/mocha": "~9.0.0",
    "@types/multer": "~1.4.7",
    "@types/node": "~14.14.31",
    "@types/object-inspect": "~1.8.1",
    "@types/pg": "^8.6.6",
    "@types/sinon": "^10.0.15",
    "@types/sinon-chai": "^3.2.9",
    "@types/swagger-ui-express": "~4.1.3",
    "@types/uuid": "^8.3.4",
    "@types/yamljs": "~0.2.31",
    "@typescript-eslint/eslint-plugin": "~4.33.0",
    "@typescript-eslint/parser": "~4.33.0",
    "chai": "^4.3.7",
    "del": "~6.0.0",
    "eslint": "~7.32.0",
    "eslint-config-prettier": "~6.15.0",
    "eslint-plugin-prettier": "~3.3.1",
    "gulp": "~4.0.2",
    "gulp-typescript": "~5.0.1",
    "mocha": "~8.4.0",
    "nodemon": "^2.0.22",
    "npm-run-all": "~4.1.5",
    "nyc": "~15.1.0",
    "prettier": "~2.3.2",
    "prettier-plugin-organize-imports": "~2.3.4",
    "sinon": "~11.1.2",
    "sinon-chai": "~3.7.0",
    "ts-mocha": "~8.0.0",
    "ts-node": "~10.4.0"
  }
}
